# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# E2E Test Credentials (for Playwright)
TEST_PARENT_EMAIL=test-parent@example.com
TEST_PARENT_PASSWORD=testpassword123
TEST_CHILD_EMAIL=test-child@example.com
TEST_CHILD_PASSWORD=testpassword123

# Observability Dashboard (required for /admin/observability)
ADMIN_OBSERVABILITY_PASSWORD=         # Password to access the admin dashboard
ADMIN_SESSION_SECRET=                 # Random 64-char string for signing session tokens
NEXT_PUBLIC_OBSERVABILITY_INGEST_TOKEN=  # Random 32-char string for ingest endpoint
